generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tutor {
  id         Int     @id @default(autoincrement())
  name       String
  email      String  @unique
  category   String
  subjects   Json
  curriculum Json
  bio        String  @db.Text
  education  String? @db.Text
  hourlyRate Int

  reviews  Review[]
  bookings Booking[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String   @db.Text
  student   String
  createdAt DateTime @default(now())
  tutorId   Int
  tutor     Tutor    @relation(fields: [tutorId], references: [id])

  @@index([tutorId], map: "Review_tutorId_fkey")
}

model Booking {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  studentName    String
  studentEmail   String
  subject        String
  preferredTimes String   @db.Text
  message        String?  @db.Text
  status         String   @default("pending")
  acceptToken    String   @unique
  declineToken   String   @unique
  tutorId        Int
  tutor          Tutor    @relation(fields: [tutorId], references: [id])

  @@index([tutorId], map: "Booking_tutorId_fkey")
}
