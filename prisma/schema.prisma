generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STUDENT
  TUTOR
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           UserRole  @default(STUDENT)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  tutor           Tutor?
  studentBookings Booking[]                @relation("StudentBookings")
  assignedTutors  StudentTutorAssignment[] @relation("StudentAssignments")
}

model Tutor {
  id         Int     @id @default(autoincrement())
  name       String
  email      String  @unique
  category   String
  subjects   Json
  curriculum Json
  bio        String  @db.Text
  education  String? @db.Text
  hourlyRate Int
  userId     String? @unique

  user             User?                    @relation(fields: [userId], references: [id])
  reviews          Review[]
  bookings         Booking[]
  assignedStudents StudentTutorAssignment[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String   @db.Text
  student   String
  createdAt DateTime @default(now())
  tutorId   Int

  tutor Tutor @relation(fields: [tutorId], references: [id])

  @@index([tutorId], map: "Review_tutorId_fkey")
}

model Booking {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  studentName    String
  studentEmail   String
  subject        String
  preferredTimes String   @db.Text
  message        String?  @db.Text
  status         String   @default("pending")
  acceptToken    String   @unique
  declineToken   String   @unique

  tutorId       Int
  studentUserId String?

  tutor       Tutor @relation(fields: [tutorId], references: [id])
  studentUser User? @relation("StudentBookings", fields: [studentUserId], references: [id])

  @@index([tutorId], map: "Booking_tutorId_fkey")
  @@index([studentUserId])
}

model StudentTutorAssignment {
  id               Int      @id @default(autoincrement())
  tutorId          Int
  studentId        String
  createdAt        DateTime @default(now())
  accumulatedTotal Decimal  @default(0.00) @db.Decimal(10, 2)

  tutor    Tutor @relation(fields: [tutorId], references: [id])
  student  User  @relation("StudentAssignments", fields: [studentId], references: [id])
  sessions TeachingSession[]

  @@unique([tutorId, studentId])
  @@index([studentId])
}

model TeachingSession {
  id            Int      @id @default(autoincrement())
  assignmentId  Int
  lessonDate    DateTime
  startTime     String
  endTime       String
  notes         String?  @db.Text
  durationHours Decimal  @db.Decimal(5, 2)
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignment StudentTutorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([lessonDate])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}